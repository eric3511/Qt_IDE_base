# ========================================
# 1. 编译输出目录 (Build Directories)
# ========================================
build/
build-*/
bin/
lib/

# ========================================
# 2. Qt Creator IDE 配置文件
# ========================================
# 忽略本地用户的环境配置（截图中的 CMakeLists.txt.user）
*.user
*.user.*

# ========================================
# 3. CMake 临时与缓存文件
# ========================================
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
.cmake/

# ========================================
# 4. Qt 自动生成的中间文件
# ========================================
moc_*.cpp
qrc_*.cpp
ui_*.h
*.qm
*.prl
*_autogen/

# ========================================
# 5. C++ 编译中间产物及 MSVC 相关文件
# ========================================
*.obj
*.o
*.exe
*.dll
*.lib
*.a
*.so
*.pdb
*.exp
*.ilk
*.idb
.vs/
*.sln
*.suo
*.vcxproj
*.vcxproj.*

# ========================================
# 6. 操作系统自动生成的文件
# ========================================
Thumbs.db
Desktop.ini
.DS_Store